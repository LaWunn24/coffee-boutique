{
  "version": 2,
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/coffee",
      "dest": "/coffee.html"
    },
    {
      "src": "/equipment",
      "dest": "/equipment.html"
    },
    {
      "src": "/events",
      "dest": "/events.html"
    },
    {
      "src": "/cart",
      "dest": "/cart.html"
    },
    {
      "src": "/offers",
      "dest": "/offers.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}